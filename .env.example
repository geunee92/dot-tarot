# Copy to .env and fill in real values. Expo inlines EXPO_PUBLIC_* vars into the bundle at build time.
# NOTE: values shipped to the client are NOT truly secret (they are embedded in the app binary).
# The APP_KEY only deters casual abuse — real protection lives server-side (rate limits, budget caps).

# AI interpretation API (Cloudflare Worker). Must match the APP_KEY set on the Worker.
EXPO_PUBLIC_TARO_API_URL=https://your-worker.workers.dev
EXPO_PUBLIC_TARO_APP_KEY=your-app-secret-key

# AdMob production rewarded ad unit IDs (falls back to Google test IDs when unset)
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
EXPO_PUBLIC_ADMOB_REWARDED_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
